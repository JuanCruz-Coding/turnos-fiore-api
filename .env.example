# Base de datos PostgreSQL (Railway provee esta variable automáticamente)
DATABASE_URL=postgresql://usuario:password@host:puerto/base

# JWT - generá un string largo y aleatorio
JWT_SECRET=cambiar_por_un_secreto_largo_y_aleatorio

# Credenciales del panel admin (reemplazar con valores reales)
ADMIN_USUARIO=fiore
ADMIN_PASSWORD=tu_password_seguro

# URLs (sin barra al final)
FRONTEND_URL=https://tu-frontend.vercel.app
BACKEND_URL=https://tu-api.up.railway.app

# Mercado Pago
MP_ACCESS_TOKEN=tu_access_token_de_mercadopago
